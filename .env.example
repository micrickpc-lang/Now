PHONE_HASH_SECRET=development-only-change-to-at-least-32-bytes
LOCATION_MASTER_KEY_BASE64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
ALLOW_DEV_OTP=true
DEV_OTP_CODE=123456
OTP_TTL_SECONDS=300
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
APP_ORIGINS=http://localhost:3001,http://localhost:8080
PUBLIC_API_URL=http://localhost:3000/api/v1
INTERNAL_MARTIN_URL=http://martin:3000
INTERNAL_NOMINATIM_URL=http://nominatim:8080
MAP_PUBLIC_BASE_URL=http://localhost:8080/maps
MINIO_ENDPOINT=minio
