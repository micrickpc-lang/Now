{
  "name": "@seychas/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"{src,test,prisma}/**/*.{ts,tsx}\"",
    "test": "jest --runInBand",
    "test:integration": "jest --config test/jest-integration.json --runInBand",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:delete-user": "tsx src/cli/delete-user.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/platform-socket.io": "11.1.28",
    "@nestjs/swagger": "11.4.6",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "11.1.28",
    "@aws-sdk/client-s3": "3.1092.0",
    "@aws-sdk/s3-request-presigner": "3.1092.0",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "argon2": "0.44.0",
    "bullmq": "5.80.10",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "cookie-parser": "1.4.7",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "libphonenumber-js": "1.12.24",
    "pg": "8.16.3",
    "prom-client": "15.1.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sharp": "0.35.3",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "9.36.0",
    "@nestjs/cli": "11.0.24",
    "@nestjs/testing": "11.1.28",
    "@types/cookie-parser": "1.4.9",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/multer": "2.0.0",
    "@types/node": "24.5.2",
    "@types/pg": "8.15.5",
    "@types/supertest": "6.0.3",
    "eslint": "9.36.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.4.0",
    "jest": "30.4.2",
    "prisma": "7.9.0",
    "supertest": "7.1.4",
    "ts-jest": "29.4.11",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "typescript-eslint": "8.44.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/generated/**",
      "!src/main.ts"
    ]
  }
}
